# Copy this file to scripts/dev-local.env.
#
# AEONIC_TEST_DOMAIN should be a domain controlled in Cloudflare.
# AEONIC_DEV_SUBDOMAIN should be unique per developer so multiple laptops do
# not share the same Cloudflare Tunnel hostnames.
#
# Example local hostnames with the values below:
# - https://api-alice-local.example.com
# - https://nexus-alice-local.example.com
# - https://partner-alice-local.example.com
# - https://www-alice-local.example.com
AEONIC_TEST_DOMAIN=example.com
AEONIC_DEV_SUBDOMAIN=alice
AEONIC_TUNNEL_NAME=aeonic-alice-local
AEONIC_TMUX_SESSION=aeonic-dev
AEONIC_PATIENT_DOMAIN_ALIAS_TARGET=app.example.com
